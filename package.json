{
  "name": "webclaw-standalone",
  "version": "0.1.0",
  "description": "WebClaw 独立版 - 让 AI 像人类一样操作浏览器",
  "main": "src/cli/index.js",
  "type": "module",
  "bin": {
    "webclaw": "./src/cli/index.js"
  },
  "scripts": {
    "start": "node src/cli/index.js",
    "repl": "node src/cli/repl.js",
    "dev": "node --watch src/cli/index.js",
    "test": "node --test",
    "init": "bash init.sh",
    "install-browser": "npx playwright install chromium",
    "lint": "eslint src/"
  },
  "keywords": [
    "browser",
    "automation",
    "playwright",
    "ai",
    "agent",
    "webclaw"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "playwright": "^1.42.0",
    "commander": "^12.0.0",
    "inquirer": "^9.2.0",
    "chalk": "^5.3.0",
    "ora": "^8.0.0",
    "dotenv": "^16.4.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
