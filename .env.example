# WebClaw 独立版 - 环境变量配置示例
# 复制此文件为 .env 并填入实际值

# ====================
# 扣子 API 配置（必须）
# ====================
COZE_API_TOKEN=your_coze_api_token_here

# API 端点（可选，默认使用扣子中国区）
COZE_ENDPOINT=https://api.coze.cn

# 模型（可选）
COZE_MODEL=coze-flash

# ====================
# 浏览器配置（可选）
# ====================
# 浏览器类型: chromium, firefox, webkit
BROWSER_TYPE=chromium

# 是否无头模式运行
HEADLESS=false

# 视口大小
VIEWPORT_WIDTH=1280
VIEWPORT_HEIGHT=800

# 浏览器超时（毫秒）
BROWSER_TIMEOUT=30000

# ====================
# 日志配置（可选）
# ====================
# 日志级别: error, warn, info, debug
LOG_LEVEL=info

# ====================
# 代理配置（可选）
# ====================
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890
