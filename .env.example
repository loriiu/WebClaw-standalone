# WebClaw 独立版 - 环境变量配置示例
# 复制此文件为 .env 并填入实际值

# ====================
# API 类型配置（必须）
# ====================
# 可选值: coze (默认), openai, anthropic, custom
API_TYPE=coze

# API Key/Token（必填，根据 API_TYPE 使用不同的变量）
# 扣子: COZE_API_TOKEN
# OpenAI: OPENAI_API_KEY
# Anthropic: ANTHROPIC_API_KEY
# 自定义: API_KEY
COZE_API_TOKEN=your_coze_api_token_here

# ====================
# 扣子 API 配置（API_TYPE=coze）
# ====================
COZE_ENDPOINT=https://api.coze.cn
COZE_MODEL=coze-flash

# ====================
# OpenAI API 配置（API_TYPE=openai）
# ====================
# 支持 OpenAI、Azure OpenAI 及各类兼容服务
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_ENDPOINT=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Azure OpenAI 示例配置
# OPENAI_ENDPOINT=https://your-resource.openai.azure.com/v1
# OPENAI_API_KEY=your_azure_api_key

# ====================
# Anthropic Claude 配置（API_TYPE=anthropic）
# ====================
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_ENDPOINT=https://api.anthropic.com/v1
ANTHROPIC_MODEL=claude-3-5-haiku-20240620
ANTHROPIC_MAX_TOKENS=1024

# ====================
# 自定义 API 配置（API_TYPE=custom）
# ====================
# 适用于其他 OpenAI 兼容的第三方服务
API_KEY=your_api_key_here
API_BASE_URL=https://your-custom-endpoint.com/v1
API_MODEL=gpt-4

# ====================
# 浏览器配置（可选）
# ====================
# 浏览器类型: chromium, firefox, webkit
BROWSER_TYPE=chromium

# 是否无头模式运行
HEADLESS=false

# 视口大小
VIEWPORT_WIDTH=1280
VIEWPORT_HEIGHT=800

# 浏览器超时（毫秒）
BROWSER_TIMEOUT=30000

# ====================
# 日志配置（可选）
# ====================
# 日志级别: error, warn, info, debug
LOG_LEVEL=info

# ====================
# 代理配置（可选）
# ====================
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890
